import numpy as np # linear algebra
import pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)

from lifelines import CoxPHFitter # Cox Model
from sklearn.preprocessing import StandardScaler

import os,json, time
from pathlib import Path
from sklearn.model_selection import StratifiedKFold, train_test_split
import lightgbm as lgb
import xgboost as xgb
from sklearn.metrics import make_scorer
from sklearn.preprocessing import StandardScaler
from scipy.stats import norm, lognorm, expon  # for parametric survival curve approximation *need to figure this out

class CFG: #configurations are all the inputs and set up for your code
    MetaDataFile = '/content/metaData.csv'
    sampleFile = '/content/sample_submission.csv'
    testFile = '/content/test.csv'
    trainFile = '/content/train.csv'

    TIME_COL = "time_to_hit_hours" #time column
    EVENT_COL = "event"           # 1 = observed (hit), 0 = censored

metaData= pd.read_csv('/content/metaData.csv')
#metaData #repeating this direction means the metadata will be displayed
#reading the MetaDataFile from above

#assigning the data to the train data frame
trainDF = pd.read_csv('/content/train.csv')
#trainDF #repeating direction produces the output

testDF = pd.read_csv('/content/test.csv')
#testDF

print(trainDF.shape) # determining rows and columns
print(testDF.shape)

drop_cols = [ CFG.TIME_COL, CFG.EVENT_COL, 'event_start_hour', 'event_start_month', 'event_start_dayofweek' ]

features = [col for col in trainDF.columns if col not in drop_cols]

print("Number of features:", len(features))
print(features)

# Keep only modeling columns
train_model = trainDF[[CFG.TIME_COL, CFG.EVENT_COL] + features].copy()
test_model = testDF[features].copy()

# handling missing values: median fill for numeric columns
for col in features:
    median_val = train_model[col].median()
    train_model[col] = train_model[col].fillna(median_val)
    test_model[col] = test_model[col].fillna(median_val)

# scale features --> if this hurts the outcome, we can remove this later
scaler = StandardScaler()
train_model[features] = scaler.fit_transform(train_model[features])
test_model[features] = scaler.transform(test_model[features])

# Cox Model
cph = CoxPHFitter(penalizer=0.1)
cph.fit(
    train_model,
    duration_col=CFG.TIME_COL,
    event_col=CFG.EVENT_COL
)

# View model summary
cph.print_summary()

horizons = [12, 24, 48, 72]

# This returns survival probability S(t) for each test row at each horizon
surv = cph.predict_survival_function(test_model, times=horizons)

# surv has rows = time horizons, cols = individual test observations
# Convert to probability of hit by horizon: 1 - S(t)
pred_hit = 1 - surv.T

# Rename columns to submission-style names
pred_hit.columns = [f"hit_by_{h}h" for h in horizons]

print(pred_hit.head())

print(pred_hit)

submission = pd.read_csv('/content/sample_submission.csv')

# Fill the submission columns with the predicted probabilities
submission['prob_12h'] = pred_hit['hit_by_12h']
submission['prob_24h'] = pred_hit['hit_by_24h']
submission['prob_48h'] = pred_hit['hit_by_48h']
submission['prob_72h'] = pred_hit['hit_by_72h']

submission.to_csv("WiDS_Spring_maddie1.csv", index=False)
print("Created submission.csv")
